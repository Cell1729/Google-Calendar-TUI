/* Google Calendar TUI Styles - Renewed Layout */

Screen {
    background: #1a1b26;
    color: #c0caf5;
}

#app-body {
    height: 1fr;
    width: 100%;
}

#sidebar {
    width: 30;
    height: 100%;
    background: #24283b;
    border-right: solid #414868;
}

#main-content {
    width: 1fr;
    height: 100%;
    background: #1a1b26;
}

#header-info {
    height: 3;
    content-align: center middle;
    background: #414868;
    color: #c0caf5;
    text-style: bold;
}

#view-switcher {
    height: 1fr; /* カレンダーが優先的に広がる */
    width: 100%;
}

CalendarWidget, WeekWidget, DayWidget {
    height: 100%;
    width: 100%;
}

.calendar-grid {
    layout: grid;
    grid-size: 7 6;
    grid-columns: 1fr 1fr 1fr 1fr 1fr 1fr 1fr;
    grid-rows: 1fr 1fr 1fr 1fr 1fr 1fr; /* 高さを均等に固定 */
    border: solid #414868;
    height: 1fr;
}

CalendarDay {
    background: #1f2335;
    border: solid #414868;
    height: 1fr;
    color: #c0caf5;
    padding: 0 1;
}

CalendarDay:focus {
    background: #7aa2f7 20%;
    border: double #7aa2f7;
}

#day-num {
    width: 100%;
    height: 1;
    content-align: right top;
    color: #7aa2f7;
    text-style: bold;
}

#cell-event-list {
    width: 100%;
    height: 1fr;
    color: #9aa5ce;
    overflow: hidden;
}

CalendarDay:focus #cell-event-list {
    color: white;
}

#weather-panel {
    height: auto;
    background: transparent;
    padding: 0 2;
    margin-top: 1;
}

#weather-content {
    height: 3;
    align: left middle;
}

#weather-icon {
    margin-right: 2;
    color: #ff9e64;
    text-style: bold;
}

#weather-temp {
    text-style: bold;
    color: #f7768e;
}

.panel-title {
    color: #565f89;
    text-style: bold;
    margin: 1 0 0 0;
}

/* Sidebar Button Styles */
Sidebar Button {
    margin: 0;
    width: 100%;
    height: 1; /* 高さを最小化 */
    background: transparent;
    border: none;
    text-align: left;
    padding-left: 2;
}

Sidebar Button:hover {
    background: #2ac3de 15%;
}

Sidebar Button.-active {
    background: #7aa2f7 20%;
    color: #7aa2f7;
    text-style: bold;
    border-left: solid #7aa2f7;
}

.sidebar-title {
    color: #565f89;
    text-style: bold;
    margin: 1 0 0 1;
}

#calendar-container, #upcoming-container {
    height: auto;
    padding-left: 2;
    margin-bottom: 1;
}

#calendar-list, #sidebar-upcoming {
    color: #9aa5ce;
}

#day-names {
    height: 1;
}

.day-name {
    width: 1fr;
    text-align: center;
    text-style: bold;
    color: #7aa2f7;
}
